{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": "rds-db:connect",
      "Resource": [
        "arn:aws:rds-db:us-east-1:ACCOUNT_ID:dbuser:RESOURCE_ID/write_user",
        "arn:aws:rds-db:us-east-1:ACCOUNT_ID:dbuser:RESOURCE_ID/readonly_user"
      ]
    }
  ]
}
